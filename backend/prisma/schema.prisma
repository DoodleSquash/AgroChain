// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model FarmerType {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  usage Int    @default(0)
}


// User role enum
enum Role {
  FARMER
  BUYER
  ADMIN
  WAREHOUSE
}

// Model: User
model User {
  id            String    @id @default(uuid()) @db.Uuid
  role          Role      @default(FARMER)
  name          String
  phone         String?
  email         String    @unique
  password      String?
  is_verified   Boolean   @default(false)
  otp_code      String?
  otp_expiry    DateTime?
  created_at    DateTime  @default(now())

  batches       Batch[]
  orders        Order[]   @relation("BuyerOrders")
  hiring_jobs   HiringJob[] @relation("FarmerHiring")
  warehouses    Warehouse[] @relation("BuyerWarehouses")
  transporters  TransporterRecord[] @relation("BuyerTransporters")
  profile       Profile?
  farmer_chats  Chat[]    @relation("FarmerChats")
  buyer_chats   Chat[]    @relation("BuyerChats")
}

// Batch Status Enum
enum BatchStatus {
  ACTIVE
  SOLD
  EXPIRED
  PAUSED
}

// Model: Batch (Farm Listing)
model Batch {
  id              String        @id @default(uuid()) @db.Uuid
  farmer_id       String        @db.Uuid
  farmer          User          @relation(fields: [farmer_id], references: [id])
  crop            String
  category        String        @default("Vegetables")
  quantity        Float         // in KG or standard unit
  price_per_unit  Float
  total_price     Float?        // Calculated, but allowed nullable
  harvest_date    DateTime
  expiry_date     DateTime?
  location        String?
  qr_code_url     String?
  status          BatchStatus   @default(ACTIVE)
  badges          String[]      @default([])
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  images          BatchImage[]
  orders          Order[]
  tracking_logs   TrackingLog[]
}

// Model: Batch Images
model BatchImage {
  id         String   @id @default(uuid()) @db.Uuid
  batch_id   String   @db.Uuid
  batch      Batch    @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  image_url  String
}

// Order Status Enum
enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

// Model: Order
model Order {
  id            String        @id @default(uuid()) @db.Uuid
  batch_id      String        @db.Uuid
  batch         Batch         @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  buyer_id      String        @db.Uuid
  buyer         User          @relation("BuyerOrders", fields: [buyer_id], references: [id])
  warehouse_id  String?       @db.Uuid
  warehouse     Warehouse?    @relation(fields: [warehouse_id], references: [id])
  quantity      Float
  total_amount  Float
  status        OrderStatus   @default(PENDING)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  escrow_account EscrowAccount?
  jobs           Job[]
  disputes       Dispute[]
  payments       Payment[]
}

// ... existing enums and models ...

// Warehouse Models
model Warehouse {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  location    String
  buyer_id    String   @db.Uuid
  buyer       User     @relation("BuyerWarehouses", fields: [buyer_id], references: [id])
  workers     WarehouseWorker[]
  orders      Order[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model WarehouseWorker {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  warehouse_id String    @db.Uuid
  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  otp_code     String?
  otp_expiry   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

// Transporter Directory for Buyers
model TransporterRecord {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String
  buyer_id    String   @db.Uuid
  buyer       User     @relation("BuyerTransporters", fields: [buyer_id], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// Escrow Status Enum
enum EscrowStatus {
  INITIATED
  FUNDED
  PARTIAL_RELEASED
  COMPLETED
  DISPUTED
  REFUNDED
}

// Model: Escrow Account
model EscrowAccount {
  id                String       @id @default(uuid()) @db.Uuid
  order_id          String       @unique @db.Uuid
  order             Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  total_amount      Float
  released_amount   Float        @default(0)
  remaining_amount  Float
  status            EscrowStatus @default(INITIATED)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  transactions      EscrowTransaction[]
}

// Model: Escrow Transactions
model EscrowTransaction {
  id                String         @id @default(uuid()) @db.Uuid
  escrow_id         String         @db.Uuid
  escrow            EscrowAccount  @relation(fields: [escrow_id], references: [id], onDelete: Cascade)
  type              String         // 'DEPOSIT', 'PARTIAL_RELEASE', 'FINAL_RELEASE', 'REFUND'
  amount            Float
  created_at        DateTime       @default(now())
}

// Job Type Enum
enum JobType {
  TRANSPORT
  WAREHOUSE
}

// Job Status Enum
enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// Model: Jobs (Logistic Links)
model Job {
  id         String     @id @default(uuid()) @db.Uuid
  order_id   String     @db.Uuid
  order      Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  type       JobType
  token      String     @unique // Secure link token
  status     JobStatus  @default(PENDING)
  link_url   String?
  details    Json?
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
}

// Model: Tracking Logs
model TrackingLog {
  id         String     @id @default(uuid()) @db.Uuid
  batch_id   String     @db.Uuid
  batch      Batch      @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  event_type String     // 'CREATED', 'PICKED_UP', 'STORED', 'DELIVERED'
  image_url  String?
  metadata   Json?
  timestamp  DateTime   @default(now())
}

// Dispute Status Enum
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

// Model: Disputes
model Dispute {
  id         String         @id @default(uuid()) @db.Uuid
  order_id   String         @db.Uuid
  order      Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  reason     String
  status     DisputeStatus  @default(OPEN)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

// Payment Status Enum
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// Model: Payments
model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  order_id   String        @db.Uuid
  order      Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  provider   String
  status     PaymentStatus @default(PENDING)
  tx_id      String?       @unique
  amount     Float
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
}

// Hire Status Enum
enum HireStatus {
  OPEN
  CLOSED
}

// Model: HiringJob (Farmer Hiring)
model HiringJob {
  id              String           @id @default(uuid()) @db.Uuid
  farmer_id       String           @db.Uuid
  farmer          User             @relation("FarmerHiring", fields: [farmer_id], references: [id])
  title           String
  location        String
  lat             Float?
  lng             Float?
  wage            String
  workers_needed  Int
  work_date       DateTime
  description     String?
  status          HireStatus       @default(OPEN)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  applications    JobApplication[]
}

// Model: JobApplication
model JobApplication {
  id                String    @id @default(uuid()) @db.Uuid
  job_id            String    @db.Uuid
  job               HiringJob @relation(fields: [job_id], references: [id], onDelete: Cascade)
  name              String
  phone             String
  skills            String?
  candidate_location String?
  lat               Float?
  lng               Float?
  applied_at        DateTime  @default(now())
}

// Model: Profile
model Profile {
  id               String  @id @default(uuid()) @db.Uuid
  user_id          String  @unique @db.Uuid
  user             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  location         String?
  profile_picture  String?
  bio              String?
  
  // farmer
  farmer_type      String?
  rating           Float   @default(0)
  review_count     Int     @default(0)
  
  // buyer
  company_name     String?
  warehouse_address String?
  buyer_type       String?
  purchasing_prefs  String?
  price_range      String?
}

// Model: Chat
model Chat {
  id               String    @id @default(uuid()) @db.Uuid
  farmer_id        String    @db.Uuid
  buyer_id         String    @db.Uuid
  farmer           User      @relation("FarmerChats", fields: [farmer_id], references: [id])
  buyer            User      @relation("BuyerChats", fields: [buyer_id], references: [id])
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  messages         Message[]

  @@unique([farmer_id, buyer_id])
}

// Model: Message
model Message {
  id         String   @id @default(uuid()) @db.Uuid
  chat_id    String   @db.Uuid
  chat       Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender_id  String   @db.Uuid
  content    String?
  image_url  String?
  created_at DateTime @default(now())
}

// Model: Connection
model Connection {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  connected_user_id String @db.Uuid
  created_at DateTime @default(now())

  @@unique([user_id, connected_user_id])
}
