// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User role enum
enum Role {
  FARMER
  BUYER
  ADMIN
}

// Model: User
model User {
  id            String    @id @default(uuid()) @db.Uuid
  role          Role      @default(FARMER)
  name          String
  phone         String?
  email         String    @unique
  is_verified   Boolean   @default(false)
  otp_code      String?
  otp_expiry    DateTime?
  created_at    DateTime  @default(now())

  batches       Batch[]
  orders        Order[]   @relation("BuyerOrders")
}

// Batch Status Enum
enum BatchStatus {
  ACTIVE
  SOLD
  EXPIRED
  PAUSED
}

// Model: Batch (Farm Listing)
model Batch {
  id              String        @id @default(uuid()) @db.Uuid
  farmer_id       String        @db.Uuid
  farmer          User          @relation(fields: [farmer_id], references: [id])
  crop            String
  quantity        Float         // in KG or standard unit
  price_per_unit  Float
  total_price     Float?        // Calculated, but allowed nullable
  harvest_date    DateTime
  expiry_date     DateTime?
  location        String?
  qr_code_url     String?
  status          BatchStatus   @default(ACTIVE)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  images          BatchImage[]
  orders          Order[]
  tracking_logs   TrackingLog[]
}

// Model: Batch Images
model BatchImage {
  id         String   @id @default(uuid()) @db.Uuid
  batch_id   String   @db.Uuid
  batch      Batch    @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  image_url  String
}

// Order Status Enum
enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

// Model: Order
model Order {
  id            String        @id @default(uuid()) @db.Uuid
  batch_id      String        @db.Uuid
  batch         Batch         @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  buyer_id      String        @db.Uuid
  buyer         User          @relation("BuyerOrders", fields: [buyer_id], references: [id])
  quantity      Float
  total_amount  Float
  status        OrderStatus   @default(PENDING)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  escrow_account EscrowAccount?
  jobs           Job[]
  disputes       Dispute[]
  payments       Payment[]
}

// Escrow Status Enum
enum EscrowStatus {
  INITIATED
  FUNDED
  PARTIAL_RELEASED
  COMPLETED
  DISPUTED
  REFUNDED
}

// Model: Escrow Account
model EscrowAccount {
  id                String       @id @default(uuid()) @db.Uuid
  order_id          String       @unique @db.Uuid
  order             Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  total_amount      Float
  released_amount   Float        @default(0)
  remaining_amount  Float
  status            EscrowStatus @default(INITIATED)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  transactions      EscrowTransaction[]
}

// Model: Escrow Transactions
model EscrowTransaction {
  id                String         @id @default(uuid()) @db.Uuid
  escrow_id         String         @db.Uuid
  escrow            EscrowAccount  @relation(fields: [escrow_id], references: [id], onDelete: Cascade)
  type              String         // 'DEPOSIT', 'PARTIAL_RELEASE', 'FINAL_RELEASE', 'REFUND'
  amount            Float
  created_at        DateTime       @default(now())
}

// Job Type Enum
enum JobType {
  TRANSPORT
  WAREHOUSE
}

// Job Status Enum
enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// Model: Jobs (Logistic Links)
model Job {
  id         String     @id @default(uuid()) @db.Uuid
  order_id   String     @db.Uuid
  order      Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  type       JobType
  token      String     @unique // Secure link token
  status     JobStatus  @default(PENDING)
  link_url   String?
  details    Json?
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
}

// Model: Tracking Logs
model TrackingLog {
  id         String     @id @default(uuid()) @db.Uuid
  batch_id   String     @db.Uuid
  batch      Batch      @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  event_type String     // 'CREATED', 'PICKED_UP', 'STORED', 'DELIVERED'
  image_url  String?
  metadata   Json?
  timestamp  DateTime   @default(now())
}

// Dispute Status Enum
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

// Model: Disputes
model Dispute {
  id         String         @id @default(uuid()) @db.Uuid
  order_id   String         @db.Uuid
  order      Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  reason     String
  status     DisputeStatus  @default(OPEN)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

// Payment Status Enum
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// Model: Payments
model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  order_id   String        @db.Uuid
  order      Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  provider   String
  status     PaymentStatus @default(PENDING)
  tx_id      String?       @unique
  amount     Float
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
}
